{
  "name": "@mybrowser/mcp",
  "version": "1.0.0",
  "description": "MCP server for MyBrowser - remote browser automation over Tailscale",
  "type": "module",
  "homepage": "https://github.com/alessai/MyBrowser-MCP",
  "bugs": {
    "url": "https://github.com/alessai/MyBrowser-MCP/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alessai/MyBrowser-MCP.git"
  },
  "bin": {
    "mybrowser-mcp": "dist/index.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts && chmod +x dist/*.js",
    "dev": "tsup src/index.ts --format esm --watch",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "commander": "^13.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
